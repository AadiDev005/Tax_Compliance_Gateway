package taxrules

import (
	"context"
	"encoding/json"
	"github.com/gin-gonic/gin"
	"github.com/redis/go-redis/v9"
	"net/http"
	"time"
)

type TaxRule struct {
	ID             int     `json:"id"`
	JurisdictionID int     `json:"jurisdiction_id"`
	RuleType       string  `json:"rule_type"`
	Rate           float64 `json:"rate"`
	EffectiveDate  string  `json:"effective_date"`
	Description    string  `json:"description"`
}

type TaxRulesResponse struct {
	Data []TaxRule `json:"data"`
	Meta struct {
		Limit      int `json:"limit"`
		Page       int `json:"page"`
		Total      int `json:"total"`
		TotalPages int `json:"totalPages"`
	} `json:"meta"`
}

type Handler struct {
	redis *redis.Client
}

func NewHandler(redis *redis.Client) *Handler {
	return &Handler{redis: redis}
}

func (h *Handler) GetTaxRules(c *gin.Context) {
	ctx := c.Request.Context()
	cacheKey := "tax_rules:page1:limit10"
	
	// Try cache
	cached, err := h.redis.Get(ctx, cacheKey).Result()
	if err == nil {
		var response TaxRulesResponse
		if err := json.Unmarshal([]byte(cached), &response); err == nil {
			c.JSON(http.StatusOK, response)
			return
		}
	}
	
	// Mock DB call (replace with actual DB query)
	response := TaxRulesResponse{
		Data: []TaxRule{
			{ID: 1, JurisdictionID: 1, RuleType: "IVA", Rate: 16, EffectiveDate: "2025-05-01", Description: "Standard IVA"},
			{ID: 2, JurisdictionID: 2, RuleType: "VAT", Rate: 19, EffectiveDate: "2025-05-01", Description: "Standard VAT"},
			{ID: 3, JurisdictionID: 3, RuleType: "ICMS", Rate: 17, EffectiveDate: "2025-05-01", Description: "Standard ICMS"},
			{ID: 4, JurisdictionID: 4, RuleType: "GST", Rate: 10, EffectiveDate: "2025-05-01", Description: "Standard GST"},
			{ID: 5, JurisdictionID: 5, RuleType: "HST", Rate: 13, EffectiveDate: "2025-05-01", Description: "Standard HST"},
		},
		Meta: struct {
			Limit      int `json:"limit"`
			Page       int `json:"page"`
			Total      int `json:"total"`
			TotalPages int `json:"totalPages"`
		}{Limit: 10, Page: 1, Total: 5, TotalPages: 1},
	}
	
	// Cache response
	data, _ := json.Marshal(response)
	h.redis.Set(ctx, cacheKey, data, 5*time.Minute)
	
	c.JSON(http.StatusOK, response)
}
